rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'gender', 'level', 'className']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.gender in ['ប្រុស', 'ស្រី'] &&
             data.level in ['ឆ្នើម', 'សកម្ម', 'អភិវឌ្ឍ', 'កំពុងរីកចម្រើន'] &&
             data.className in ['ថ្នាក់ទី៧ក', 'ថ្នាក់ទី៨ក', 'ថ្នាក់ទី៩ក'];
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /teachers/{userId} {
      allow get: if isOwner(userId);
      
      match /students/{studentId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(studentId) && isValidStudent(incoming());
        allow update: if isOwner(userId) && isValidStudent(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
